@page "/quiz"
@inject IJSRuntime JS
@inject LanguageService Lang
@implements IDisposable

<PageTitle>@Strings.NavQuiz(Lang.Current) – TinyTutor</PageTitle>

<PageHeader Title="@Strings.QuizTitle(Lang.Current)">
    <Action>
        <button class="quiz-cfg-btn" @onclick="() => showSettings = !showSettings">
            @(showSettings ? "✕" : "⚙️")
        </button>
    </Action>
</PageHeader>

<span class="current-mode-label">@ModeLabel(currentMode)</span>

@* ── Collapsible config (modes + auto-advance) ─────────────── *@
<div class="quiz-config @(showSettings ? "cfg-open" : "")">
    <div class="quiz-modes">
        @foreach (var m in AllModes)
        {
            var mode = m;
            var enabled = enabledModes.Contains(mode);
            var isOnly  = enabledModes.Count == 1 && enabled;
            <button class="mode-btn @(enabled ? "mode-active" : "mode-off") @(isOnly ? "mode-only" : "")"
                    @onclick="() => ToggleMode(mode)"
                    disabled="@isOnly">
                @ModeLabel(mode)
            </button>
        }
    </div>

    <div class="quiz-settings">
        <span class="settings-label">@Strings.QuizAutoNext(Lang.Current)</span>
        <div class="delay-options">
            @foreach (var (label, secs) in DelayOptions)
            {
                var s = secs;
                <button class="delay-btn @(autoAdvanceSeconds == s ? "delay-active" : "")"
                        @onclick="() => SetDelay(s)">
                    @label
                </button>
            }
        </div>
    </div>
</div>

@* ── Question ─────────────────────────────────────────────── *@
<div class="quiz-question">
    @if (currentMode == QuizMode.Word)
    {
        <div class="quiz-word">@NumberHelper.GetDisplayWord(targetNumber, Lang.Current)</div>
        <TtButton Variant="icon" OnClick="HearQuestion">🔊</TtButton>
    }
    else if (currentMode == QuizMode.Count)
    {
        <p class="quiz-question-text">@QuestionText</p>
        <div class="quiz-dots-box">
            <div class="quiz-dots">
                @for (int i = 0; i < targetNumber; i++)
                {
                    <div class="dot-circle"></div>
                }
            </div>
        </div>
    }
    else
    {
        <p class="quiz-question-text">@QuestionText</p>
        <div class="quiz-sequence">
            @if (currentMode == QuizMode.Before)
            {
                <div class="sequence-box seq-blank">?</div>
                <div class="sequence-arrow">→</div>
                <div class="sequence-box seq-given">@questionNum</div>
            }
            else if (currentMode == QuizMode.After)
            {
                <div class="sequence-box seq-given">@questionNum</div>
                <div class="sequence-arrow">→</div>
                <div class="sequence-box seq-blank">?</div>
            }
            else if (currentMode == QuizMode.Between)
            {
                <div class="sequence-box seq-given">@questionNum</div>
                <div class="sequence-arrow">→</div>
                <div class="sequence-box seq-blank">?</div>
                <div class="sequence-arrow">→</div>
                <div class="sequence-box seq-given">@questionNum2</div>
            }
        </div>
        <TtButton Variant="icon" OnClick="HearQuestion">🔊</TtButton>
    }
</div>

@* ── Choices ──────────────────────────────────────────────── *@
<div class="quiz-choices">
    @foreach (var choice in choices)
    {
        var c = choice;
        var cls = (solved && c == targetNumber) ? "btn-correct"
                : wrongAttempts.Contains(c)     ? "btn-wrong"
                :                                 "btn-choice";
        var disabled = solved || wrongAttempts.Contains(c);
        <button class="btn quiz-btn @cls" @onclick="() => Answer(c)" disabled="@disabled">
            @c
        </button>
    }
</div>

@* ── Feedback + next row ──────────────────────────────────── *@
@if (solved)
{
    <div class="quiz-feedback feedback-correct">
        @Strings.QuizCorrect(Lang.Current) @NumberHelper.GetDisplayWord(targetNumber, Lang.Current)!
    </div>

    <div class="quiz-next-row">
        <TtButton Variant="primary" OnClick="NextQuestion">@Strings.QuizNext(Lang.Current)</TtButton>
        @if (autoAdvanceSeconds > 0 && countdownRemaining > 0)
        {
            <span class="countdown-badge">@countdownRemaining</span>
        }
    </div>
}

@* ── Score ────────────────────────────────────────────────── *@
<div class="quiz-score">
    @Strings.QuizScore(Lang.Current): @score / @asked
    @if (streak >= 2)
    {
        <span class="quiz-streak">🔥 @streak</span>
    }
</div>


@code {
    private enum QuizMode { Word, Before, After, Between, Count }

    private static readonly QuizMode[]  AllModes = Enum.GetValues<QuizMode>();
    private static readonly Random      Rng      = new();

    private static readonly (string Label, int Secs)[] DelayOptions =
        [("Off", 0), ("2s", 2), ("3s", 3), ("5s", 5)];

    // ── State ──────────────────────────────────────────────
    private HashSet<QuizMode> enabledModes = new(Enum.GetValues<QuizMode>());
    private QuizMode currentMode;
    private int targetNumber;
    private int questionNum;
    private int questionNum2;
    private List<int> choices = [];
    private bool solved;
    private HashSet<int> wrongAttempts = [];
    private int score;
    private int asked;
    private int streak;

    // ── UI state ───────────────────────────────────────────
    private bool showSettings;

    // ── Auto-advance ───────────────────────────────────────
    private int autoAdvanceSeconds = 3;
    private int countdownRemaining;
    private CancellationTokenSource? _cts;

    // ── Lifecycle ──────────────────────────────────────────
    protected override void OnInitialized()
    {
        Lang.OnChange += OnLanguageChanged;
        NewQuestion();
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Lang.OnChange -= OnLanguageChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }

    // ── Computed ───────────────────────────────────────────
    private string ModeLabel(QuizMode m) => m switch
    {
        QuizMode.Word    => Strings.QuizModeWord(Lang.Current),
        QuizMode.Before  => Strings.QuizModeBefore(Lang.Current),
        QuizMode.After   => Strings.QuizModeAfter(Lang.Current),
        QuizMode.Between => Strings.QuizModeBetween(Lang.Current),
        QuizMode.Count   => Strings.QuizModeCount(Lang.Current),
        _                => ""
    };

    private string QuestionText => currentMode switch
    {
        QuizMode.Before  => Strings.QuizBefore(Lang.Current, questionNum),
        QuizMode.After   => Strings.QuizAfter(Lang.Current, questionNum),
        QuizMode.Between => Strings.QuizBetween(Lang.Current, questionNum, questionNum2),
        QuizMode.Count   => Strings.QuizCountDots(Lang.Current),
        _                => ""
    };

    // ── Mode toggling ──────────────────────────────────────
    void ToggleMode(QuizMode m)
    {
        if (enabledModes.Contains(m))
        {
            if (enabledModes.Count == 1) return; // keep at least one
            enabledModes.Remove(m);
        }
        else
        {
            enabledModes.Add(m);
        }
    }

    // ── Delay setting ──────────────────────────────────────
    void SetDelay(int secs) => autoAdvanceSeconds = secs;

    // ── Question generation ────────────────────────────────
    void NewQuestion()
    {
        CancelCountdown();
        solved        = false;
        wrongAttempts = [];

        // Pick a random enabled mode
        var pool = enabledModes.ToArray();
        currentMode  = pool[Rng.Next(pool.Length)];

        switch (currentMode)
        {
            case QuizMode.Word:
                targetNumber = Rng.Next(1, 31);
                choices      = GenerateChoices(targetNumber);
                break;

            case QuizMode.Before:
                questionNum  = Rng.Next(2, 31);
                targetNumber = questionNum - 1;
                choices      = GenerateChoices(targetNumber, questionNum);
                break;

            case QuizMode.After:
                questionNum  = Rng.Next(1, 30);
                targetNumber = questionNum + 1;
                choices      = GenerateChoices(targetNumber, questionNum);
                break;

            case QuizMode.Between:
                targetNumber = Rng.Next(2, 30);
                questionNum  = targetNumber - 1;
                questionNum2 = targetNumber + 1;
                choices      = GenerateChoices(targetNumber, questionNum, questionNum2);
                break;

            case QuizMode.Count:
                targetNumber = Rng.Next(1, 21);
                choices      = GenerateChoices(targetNumber);
                break;
        }
    }

    List<int> GenerateChoices(int correct, params int[] exclude)
    {
        var excluded = new HashSet<int>(exclude) { correct };
        var pool     = new HashSet<int> { correct };

        for (int attempt = 0; pool.Count < 4 && attempt < 200; attempt++)
        {
            int candidate = Math.Clamp(correct + Rng.Next(-5, 6), 1, 30);
            if (!excluded.Contains(candidate)) pool.Add(candidate);
        }

        for (int n = 1; n <= 30 && pool.Count < 4; n++)
            if (!excluded.Contains(n)) pool.Add(n);

        return pool.OrderBy(_ => Rng.Next()).ToList();
    }

    // ── Speech ─────────────────────────────────────────────
    async Task HearQuestion()
    {
        var text = currentMode == QuizMode.Word
            ? NumberHelper.GetSpeechWord(targetNumber, Lang.Current)
            : QuestionText;
        await JS.InvokeVoidAsync("speakNumber", text, Lang.LangCode);
    }

    // ── Answer handling ────────────────────────────────────
    async Task Answer(int choice)
    {
        await JS.InvokeVoidAsync("blurActive");
        if (choice == targetNumber)
        {
            solved = true;
            asked++;
            if (wrongAttempts.Count == 0) { score++; streak++; }
            var feedback = Strings.SpeakCorrectFeedback(Lang.Current, wrongAttempts.Count, streak);
            await JS.InvokeVoidAsync("speakNumber",
                feedback + NumberHelper.GetSpeechWord(targetNumber, Lang.Current),
                Lang.LangCode);
            StartCountdown();
        }
        else
        {
            streak = 0;
            wrongAttempts.Add(choice);
            await JS.InvokeVoidAsync("speakNumber", Strings.SpeakWrongFeedback(Lang.Current), Lang.LangCode);
        }
    }

    async Task NextQuestion()
    {
        NewQuestion();
        await HearQuestion();
    }

    // ── Countdown ──────────────────────────────────────────
    void StartCountdown()
    {
        if (autoAdvanceSeconds <= 0) return;

        CancelCountdown();
        var cts = new CancellationTokenSource();
        _cts = cts;
        countdownRemaining = autoAdvanceSeconds;

        _ = RunCountdown(cts.Token);
    }

    async Task RunCountdown(CancellationToken token)
    {
        try
        {
            while (countdownRemaining > 0)
            {
                await Task.Delay(1000, token);
                countdownRemaining--;
                await InvokeAsync(StateHasChanged);
            }

            if (!token.IsCancellationRequested)
        {
            await InvokeAsync(async () =>
            {
                await NextQuestion();
                StateHasChanged();
            });
        }
        }
        catch (TaskCanceledException) { }
    }

    void CancelCountdown()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
        countdownRemaining = 0;
    }
}
