@page "/"
@inject LanguageService Lang
@implements IDisposable

<PageTitle>TinyTutor</PageTitle>

<div class="home-hero">
    <h1>@Strings.HomeWelcome(Lang.Current)</h1>
    <p class="home-subtitle">@Strings.HomeSubtitle(Lang.Current)</p>
</div>

<div class="activity-cards">
    <ActivityCard Href="/chart"      Icon="🔢" Title="@Strings.NavChart(Lang.Current)"     Description="@Strings.HomeChartDesc(Lang.Current)" />
    <ActivityCard Href="/flashcards" Icon="🃏" Title="@Strings.NavFlashCards(Lang.Current)" Description="@Strings.HomeCardsDesc(Lang.Current)" />
    <ActivityCard Href="/quiz"       Icon="⭐" Title="@Strings.NavQuiz(Lang.Current)"      Description="@Strings.HomeQuizDesc(Lang.Current)" />
</div>

@code {
    protected override void OnInitialized() => Lang.OnChange += OnLanguageChanged;
    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Lang.OnChange -= OnLanguageChanged;
}
