@inject LanguageService Lang
@inject IJSRuntime JS

@* Blazor injects this into <head> via HeadOutlet — persists across SPA navigation *@
@if (_savedColor != null)
{
    <HeadContent>
        <style id="tt-theme">@((MarkupString)BuildCss(_savedColor))</style>
    </HeadContent>
}

<div class="settings-panel">
    @if (open)
    {
        <div class="settings-backdrop" @onclick="Close"></div>
    }
    <button class="settings-gear-btn" @onclick="Toggle" title="Settings">⚙️</button>
    @if (open)
    {
        <div class="settings-dropdown">

            @* ── Language ── *@
            <div class="settings-item">
                <span class="settings-item-label">Taal / Language</span>
                <div class="lang-toggle">
                    <button class="lang-btn @(Lang.IsEnglish ? "lang-active" : "")" @onclick='() => PickLang("en")'>EN</button>
                    <button class="lang-btn @(!Lang.IsEnglish ? "lang-active" : "")" @onclick='() => PickLang("nl")'>NL</button>
                </div>
            </div>

            <hr class="settings-divider" />

            @* ── Theme color ── *@
            <div class="settings-item settings-item-col">
                <span class="settings-item-label">Kleur / Color</span>
                <div class="theme-presets">
                    @foreach (var (_, hex) in Presets)
                    {
                        var h = hex;
                        <button class="theme-dot @(currentColor == h ? "theme-dot-active" : "")"
                                style="background: @h"
                                @onclick="() => PickColor(h)">
                        </button>
                    }
                    <input type="color" class="theme-custom"
                           value="@currentColor"
                           @oninput="OnCustomColor" />
                </div>
            </div>

        </div>
    }
</div>

@code {
    private bool    open;
    private string  currentColor = "#c84010";
    private string? _savedColor;

    private static readonly (string Name, string Hex)[] Presets =
    [
        ("Orange", "#c84010"),
        ("Red",    "#c82828"),
        ("Pink",   "#d44080"),
        ("Purple", "#8040c8"),
        ("Blue",   "#2060c8"),
        ("Teal",   "#108890"),
        ("Green",  "#208850"),
        ("Yellow", "#b88010"),
    ];

    private static readonly Dictionary<string,(string lt,string dk,string glow,string border,string shine,string bgc,string bgm)> Palette = new()
    {
        ["#c84010"] = ("#d45018","#8a1800","rgba(200,64,16,.45)",  "#6a1500","rgba(255,140,60,.25)", "#cc4010","#6a1a08"),
        ["#c82828"] = ("#d83838","#8a0000","rgba(200,40,40,.45)",  "#6a0000","rgba(255,96,84,.25)",  "#cc2828","#6a0808"),
        ["#d44080"] = ("#e05090","#8a1850","rgba(212,64,128,.45)", "#6a1040","rgba(255,140,172,.25)","#d44080","#6a1040"),
        ["#8040c8"] = ("#9050d8","#501888","rgba(128,64,200,.45)", "#400870","rgba(183,116,255,.25)","#8040c8","#401070"),
        ["#2060c8"] = ("#3070d8","#003888","rgba(32,96,200,.45)",  "#001870","rgba(87,172,255,.25)", "#2060c8","#001060"),
        ["#108890"] = ("#1898a0","#005860","rgba(16,136,144,.45)", "#003848","rgba(70,212,220,.25)", "#108890","#003840"),
        ["#208850"] = ("#309860","#005820","rgba(32,136,80,.45)",  "#003818","rgba(87,212,124,.25)", "#208850","#003820"),
        ["#b88010"] = ("#c89018","#785000","rgba(184,128,16,.45)", "#583000","rgba(239,204,70,.25)", "#b88010","#584000"),
    };

    private static string BuildCss(string hex)
    {
        if (Palette.TryGetValue(hex, out var p))
            return $":root{{--primary:{hex};--primary-lt:{p.lt};--primary-dk:{p.dk};--glow:{p.glow};--btn-border:{p.border};--btn-shine:{p.shine};--bg-center:{p.bgc};--bg-mid:{p.bgm};}}";

        var r = Convert.ToInt32(hex.Substring(1, 2), 16);
        var g = Convert.ToInt32(hex.Substring(3, 2), 16);
        var b = Convert.ToInt32(hex.Substring(5, 2), 16);
        var lt   = $"rgb({Math.Min(255,r+28)},{Math.Min(255,g+16)},{Math.Min(255,b+8)})";
        var dk   = $"rgb({(int)(r*.55)},{(int)(g*.38)},{(int)(b*.30)})";
        var glow = $"rgba({r},{g},{b},.45)";
        var bdr  = $"rgb({(int)(r*.40)},{(int)(g*.25)},{(int)(b*.20)})";
        var shn  = $"rgba({Math.Min(255,r+55)},{Math.Min(255,g+76)},{Math.Min(255,b+44)},.25)";
        var bgm  = $"rgb({(int)(r*.42)},{(int)(g*.30)},{(int)(b*.25)})";
        return $":root{{--primary:{hex};--primary-lt:{lt};--primary-dk:{dk};--glow:{glow};--btn-border:{bdr};--btn-shine:{shn};--bg-center:{hex};--bg-mid:{bgm};}}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedLang = await JS.InvokeAsync<string?>("getSavedLang");
            if (savedLang != null) Lang.Set(savedLang);

            _savedColor = await JS.InvokeAsync<string?>("getSavedTheme");
            if (_savedColor != null)
            {
                currentColor = _savedColor;
                StateHasChanged();
            }
        }
    }

    private void Toggle() => open = !open;
    private void Close()  => open = false;

    private async Task PickLang(string lang)
    {
        Lang.Set(lang);
        await JS.InvokeVoidAsync("saveLang", lang);
        open = false;
    }

    private async Task PickColor(string hex)
    {
        currentColor = hex;
        _savedColor  = hex;
        await JS.InvokeVoidAsync("saveTheme", hex);
    }

    private async Task OnCustomColor(ChangeEventArgs e)
    {
        var hex = e.Value?.ToString();
        if (!string.IsNullOrEmpty(hex))
            await PickColor(hex);
    }
}
